//- views/index.pug
//- Home page — extends the base layout and fills the `content` block

extends layout

//- Import all reusable mixins
include partials/mixins

block content

  //- ══════════════════════════════════════════════════════════════════════
  //- SECTION 1 — Hero
  //- ══════════════════════════════════════════════════════════════════════
  section#home.hero
    .hero__content
      p.hero__eyebrow Neque porro quisquam est qui dolorem ipsum quia
      h1.hero__title
        | Lorem Ipsum Neque
        br
        | Porro Qui Dolorem
      p.hero__body
        | Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod
        | tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim
        | veniam, quis nostrud exercitation
      .hero__actions
        a.btn--primary(href="#") Booking Now
        a.btn--outline(href="/hotels") See all hotels

    .hero__image
      .hero__image-placeholder
        i.fas.fa-image

  //- ── Search Bar ──────────────────────────────────────────────────────────
  .search-bar
    .search-bar__group
      label.search-bar__label Check in
      .search-bar__fields
        .search-bar__field
          span.search-bar__field-label Locations
          select(aria-label="Select your city")
            option Select your city
            option Paris
            option London
            option New York
        .search-bar__field
          span.search-bar__field-label Date
          select(aria-label="Check-in date")
            option Select your date
        .search-bar__field
          span.search-bar__field-label Time
          select(aria-label="Check-in time")
            option Select your time

    .search-bar__divider

    .search-bar__group
      label.search-bar__label Check out
      .search-bar__fields
        .search-bar__field
          span.search-bar__field-label Date
          select(aria-label="Check-out date")
            option Select your date
        .search-bar__field
          span.search-bar__field-label Time
          select(aria-label="Check-out time")
            option Select your time

    button.btn--search(type="button") Search

  //- ══════════════════════════════════════════════════════════════════════
  //- SECTION 2 — How It Works
  //- ══════════════════════════════════════════════════════════════════════
  section#how.how-it-works
    .section-header
      h2.section-header__title Lorem Ipsum passage
