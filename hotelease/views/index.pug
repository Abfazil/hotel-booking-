      .how-it-works__connector

      +featureStep("calendar-alt", "Pick-up Date", "Aliquam erat volutpat. Integer malesuada turpis id fringilla suscipit. Maecenas ultrices, orci vitae convallis mattis.")

      .how-it-works__connector

      +featureStep("car", "Book your hotel", "Aliquam erat volutpat. Integer malesuada turpis id fringilla suscipit. Maecenas ultrices, orci vitae convallis mattis.")

  //- ══════════════════════════════════════════════════════════════════════
  //- SECTION 3 — Hotel Listings
  //- ══════════════════════════════════════════════════════════════════════
  section#hotels.hotels
    .section-header
      h2.section-header__title Lorem ipsum dolor sit amet
      p.section-header__subtitle
        | Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed
        br
        | do eiusmod tempor incididunt ut labore et

    //- Tab navigation
    .hotels__tabs
      button.hotels__tab.hotels__tab--active(data-tab="popular") Popular
      button.hotels__tab(data-tab="executive") Executive Room
      button.hotels__tab(data-tab="ensuite") En suite Room
      button.hotels__tab(data-tab="penthouse") Penthouse

    //- Hotel grid — `hotels` array is passed from server.js
    .hotels__grid
      each hotel in hotels
        +hotelCard(hotel)

    .hotels__footer
      button.btn--show-more(type="button") Show more hotels
      span.hotels__count 120 hotels

