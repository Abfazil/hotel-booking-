extends ../layout

block content
  section.dashboard
    .dashboard__inner
      .dashboard__header
        h1.dashboard__title Admin Dashboard
        p.dashboard__subtitle Manage users, hotels, and disputes from one place.

      .dashboard__stats
        .dashboard__stat-card
          p.dashboard__stat-label Total users
          p.dashboard__stat-value= stats.totalUsers
        .dashboard__stat-card
          p.dashboard__stat-label Total bookings
          p.dashboard__stat-value= stats.totalBookings
        .dashboard__stat-card
          p.dashboard__stat-label Total disputes
          p.dashboard__stat-value= stats.totalDisputes

      .dashboard__card
        h2.dashboard__card-title Manage platform
        ul.dashboard__manage
          li
            strong View users
            p Track customer profiles and account status.
          li
            strong Manage hotels
            p Update listings and review hotel information.
          li
            strong View disputes
            p Inspect open customer disputes and resolve issues.

      .dashboard__grid
        .dashboard__card
          h2.dashboard__card-title Recent users
          if recentUsers && recentUsers.length
            ul.dashboard__list
              each user in recentUsers
                li.dashboard__list-item
                  .dashboard__item-main
                    strong #{user.name}
                    span #{user.email}
                  span.dashboard__badge= user.role
          else
            p.dashboard__empty No users found.

        .dashboard__card
          h2.dashboard__card-title Recent bookings
          if recentBookings && recentBookings.length
            ul.dashboard__list
              each booking in recentBookings
                li.dashboard__list-item
                  .dashboard__item-main
                    strong Booking ##{booking.id} - #{booking.hotelName || 'Hotel'}
                    span #{booking.createdAt}
                  span.dashboard__badge= booking.status || 'Pending'
          else
            p.dashboard__empty No bookings found.

      .dashboard__card
        h2.dashboard__card-title Recent disputes
        if recentDisputes && recentDisputes.length
          ul.dashboard__list
            each dispute in recentDisputes
              li.dashboard__list-item
                .dashboard__item-main
                  strong Dispute ##{dispute.id}
                  span #{dispute.issue}
                span.dashboard__badge= dispute.status || 'Open'
        else
          p.dashboard__empty No disputes found.
