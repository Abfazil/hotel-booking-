//- views/favourites.pug
//- Lists the logged-in user's favourited hotels.

extends layout

include partials/mixins

block content
  section.listing.listing--grid(style="padding: 3.5rem 1.5rem; background: var(--color-light-bg);")
    .section-header
      h2.section-header__title Your favourites
      p.section-header__subtitle Saved stays you can come back to anytime.

    if hotels && hotels.length
      .listing__grid(style="max-width: 1100px; margin: 0 auto;")
        each hotel in hotels
          +hotelCard(hotel)
    else
      .hotel-detail__card(style="max-width: 760px; margin: 0 auto; text-align: center;")
        h3.hotel-detail__card-title No favourites yet
        p.hotel-detail__card-text
          | Tap the heart on any hotel to save it here.
        a.btn--primary(href="/hotels") Browse hotels

