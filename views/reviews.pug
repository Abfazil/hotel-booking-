//Reviews
//Shows 3 cards per slide. Prev/next arrows + dot indicators to navigate.

if reviews && reviews.length

  section.reviews
    .reviews__inner

      .reviews__header
        h2.reviews__title What our guests say
        p.reviews__subtitle Real stays. Honest opinions.

      .reviews__track-wrapper
        button.reviews__arrow.reviews__arrow--prev(type="button" aria-label="Previous reviews")
          i.fas.fa-chevron-left

        .reviews__track
          //- JS will wrap these into a sliding row at runtime
          - const chunkSize = 3
          - const slides = []
          - for (let i = 0; i < reviews.length; i += chunkSize) { slides.push(reviews.slice(i, i + chunkSize)) }

          each slide, slideIndex in slides
            .reviews__slide(data-slide=slideIndex)
              each review in slide
                article.review-card
                  .review-card__stars
                    - for (let s = 0; s < review.rating; s++)
                      i.fas.fa-star
                    - for (let s = review.rating; s < 5; s++)
                      i.far.fa-star

                  p.review-card__quote= review.comment

                  .review-card__footer
                    .review-card__author
                      .review-card__avatar
                        i.fas.fa-user
                      div
                        p.review-card__name= review.name
                        if review.location
                          p.review-card__location= review.location
                    if review.hotel_name
                      p.review-card__hotel
                        i.fas.fa-hotel
                        |  #{review.hotel_name}

        button.reviews__arrow.reviews__arrow--next(type="button" aria-label="Next reviews")
          i.fas.fa-chevron-right

      //Dots — one per slide
      - const totalSlides = Math.ceil(reviews.length / 3)
      if totalSlides > 1
        .reviews__dots
          each _, i in Array(totalSlides).fill(0)
            button.reviews__dot(type="button" data-dot=i aria-label=`Go to slide ${i + 1}`)

  style.
    /* Reviews section */
    .reviews {
      padding: 5rem 1.5rem;
      background: var(--color-light-bg, #eef2f7);
    }

    .reviews__inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .reviews__header {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .reviews__title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      margin-bottom: .4rem;
      color: var(--color-heading, #1a1a1a);
    }

    .reviews__subtitle {
      color: var(--color-muted, #888);
      font-size: .95rem;
    }

    /* wrapper holds arrows + track */
    .reviews__track-wrapper {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .reviews__track {
      overflow: hidden;
      flex: 1;
    }

    /* JS wraps slides inside this row */
    .reviews__slides-row {
      display: flex;
      transition: transform .4s cubic-bezier(.4, 0, .2, 1);
      will-change: transform;
    }

    .reviews__slide {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      min-width: 100%;
      box-sizing: border-box;
    }

    /* Arrow buttons */
    .reviews__arrow {
      flex-shrink: 0;
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 50%;
      border: 1.5px solid rgba(29, 53, 87, 0.16);
      background: var(--color-card-bg, #dde4ed);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-heading, #1a1a1a);
      transition: background .2s, color .2s, border-color .2s;
    }

    .reviews__arrow:hover {
      background: var(--color-accent, #457b9d);
      border-color: var(--color-accent, #457b9d);
      color: #fff;
    }

    .reviews__arrow:disabled {
      opacity: .3;
      cursor: default;
      pointer-events: none;
    }

    /* Dot indicators */
    .reviews__dots {
      display: flex;
      justify-content: center;
      gap: .5rem;
      margin-top: 1.75rem;
    }

    .reviews__dot {
      width: .55rem;
      height: .55rem;
      border-radius: 50%;
      border: none;
      background: var(--color-border, #ccc);
      cursor: pointer;
      padding: 0;
      transition: background .2s, transform .2s;
    }

    .reviews__dot--active {
      background: var(--color-accent, #457b9d);
      transform: scale(1.4);
    }

    /* Review card */
    .review-card {
      background: var(--color-card-bg, #dde4ed);
      border-radius: .75rem;
      padding: 1.5rem 1.4rem;
      display: flex;
      flex-direction: column;
      gap: .75rem;
      box-shadow: var(--shadow-card, 0 2px 16px rgba(29,53,87,0.08));
      border: 1px solid rgba(29, 53, 87, 0.10);
    }

    .review-card__stars {
      color: #f4a83a;
      font-size: .9rem;
      letter-spacing: .05em;
    }

    .review-card__quote {
      font-size: .95rem;
      line-height: 1.65;
      color: var(--color-body, #444);
      flex: 1;
    }

    .review-card__footer {
      display: flex;
      flex-direction: column;
      gap: .5rem;
      margin-top: auto;
    }

    .review-card__author {
      display: flex;
      align-items: center;
      gap: .65rem;
    }

    .review-card__avatar {
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 50%;
      background: var(--color-accent, #457b9d);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: .8rem;
      flex-shrink: 0;
    }

    .review-card__name {
      font-weight: 500;
      font-size: .9rem;
      color: var(--color-heading, #1a1a1a);
      margin: 0;
    }

    .review-card__location {
      font-size: .78rem;
      color: var(--color-muted, #888);
      margin: 0;
    }

    .review-card__hotel {
      font-size: .78rem;
      color: var(--color-muted, #aaa);
      margin: 0;
    }

    .review-card__hotel i {
      margin-right: .25rem;
    }

    /* Responsive */
    @media (max-width: 900px) {
      .reviews__slide {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .reviews__slide {
        grid-template-columns: 1fr;
      }

      .reviews__arrow {
        display: none;
      }
    }

  script.
    (function () {
      //Finds the reviews section 
      document.querySelectorAll('.reviews').forEach(function (section) {
        var track   = section.querySelector('.reviews__track');
        var slides  = Array.from(section.querySelectorAll('.reviews__slide'));
        var dots    = Array.from(section.querySelectorAll('.reviews__dot'));
        var btnPrev = section.querySelector('.reviews__arrow--prev');
        var btnNext = section.querySelector('.reviews__arrow--next');

        if (!track || slides.length === 0) return;

        //Wrap all slides in a flex row so we can translate the whole row
        var row = document.createElement('div');
        row.className = 'reviews__slides-row';
        slides.forEach(function (s) { row.appendChild(s); });
        track.appendChild(row);

        var current = 0;
        var total   = slides.length;

        function goTo(index) {
          current = Math.max(0, Math.min(index, total - 1));
          row.style.transform = 'translateX(-' + (current * 100) + '%)';

          dots.forEach(function (d, i) {
            d.classList.toggle('reviews__dot--active', i === current);
          });

          if (btnPrev) btnPrev.disabled = current === 0;
          if (btnNext) btnNext.disabled = current === total - 1;
        }

        if (btnPrev) btnPrev.addEventListener('click', function () { goTo(current - 1); });
        if (btnNext) btnNext.addEventListener('click', function () { goTo(current + 1); });
        dots.forEach(function (d, i) {
          d.addEventListener('click', function () { goTo(i); });
        });

        goTo(0); 
      });
    }());























































































































































































