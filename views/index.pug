//- views/index.pug
//- Home page — extends the base layout and fills the `content` block

extends layout

//- Import all reusable mixins
include partials/mixins

block content

  //- ══════════════════════════════════════════════════════════════════════
  //- SECTION 1 — Hero
  //- ══════════════════════════════════════════════════════════════════════
  section#home.hero
    .hero__content
      p.hero__eyebrow Fresh stays, curated for you
      h1.hero__title
        | HotelEase Makes
        br
        | Booking Effortless
      p.hero__body
        | Browse featured hotels, compare clear prices, and plan your trip in minutes.
        | Choose the room you’ll love—then book with confidence, no hassle required.
      .hero__actions
        a.btn--primary(href="#") Booking Now
        a.btn--outline(href="/hotels") See all hotels

    .hero__image
      a.hero__image-placeholder(href="/hotels/1")
        img(
          src="/images/homepage_image.webp"
          alt="Featured hotel room"
          loading="eager"
        )

  //- ── Search Bar ──────────────────────────────────────────────────────────
  .search-bar
    .search-bar__group
      label.search-bar__label Check in
      .search-bar__fields
        .search-bar__field
          span.search-bar__field-label Locations
          select(aria-label="Select your city")
            option Select your city
            option Paris
            option London
            option New York
        .search-bar__field
          span.search-bar__field-label Date
          select(aria-label="Check-in date")
            option Select your date
        .search-bar__field
          span.search-bar__field-label Time
          select(aria-label="Check-in time")
            option Select your time

    .search-bar__divider

    .search-bar__group
      label.search-bar__label Check out
      .search-bar__fields
        .search-bar__field
          span.search-bar__field-label Date
          select(aria-label="Check-out date")
            option Select your date
        .search-bar__field
          span.search-bar__field-label Time
          select(aria-label="Check-out time")
            option Select your time

    button.btn--search(type="button") Search

  //- ══════════════════════════════════════════════════════════════════════
  //- SECTION 2 — How It Works
  //- ══════════════════════════════════════════════════════════════════════
  section#how.how-it-works
    .section-header
      h2.section-header__title How HotelEase Works
      p.section-header__subtitle
        | Pick your city and dates
        br
        | then choose from curated stays with transparent details.

    .how-it-works__steps
      //- Using the featureStep mixin defined in mixins.pug
      +featureStep("map-marker-alt", "Choose Location", "Tell us where you want to stay and we’ll show curated options nearby.")

      .how-it-works__connector

      +featureStep("calendar-alt", "Pick-up Date", "Select your dates to see real availability and clear nightly pricing.")

      .how-it-works__connector

      +featureStep("car", "Book your hotel", "Confirm in minutes with transparent details and instant booking confirmation.")

  //- ══════════════════════════════════════════════════════════════════════
  //- SECTION 3 — Hotel Listings
  //- ══════════════════════════════════════════════════════════════════════
  section#hotels.hotels
    .section-header
      h2.section-header__title Featured Hotels
      p.section-header__subtitle
        | From cozy retreats to modern suites, find a stay that fits your vibe.
        br
        | Explore locations, ratings, and nightly pricing at a glance.

    //- Tab navigation
    .hotels__tabs
      button.hotels__tab.hotels__tab--active(data-tab="popular") Popular
      button.hotels__tab(data-tab="executive") Executive Room
      button.hotels__tab(data-tab="ensuite") En suite Room
      button.hotels__tab(data-tab="penthouse") Penthouse

    //- Hotel grid — `hotels` array is passed from server.js
    .hotels__grid
      each hotel in hotels
        +hotelCard(hotel)

    .hotels__footer
      button.btn--show-more(type="button") Show more hotels
      span.hotels__count 120 hotels

  //- ══════════════════════════════════════════════════════════════════════
  //- SECTION 4 — Why Choose Us
  //- ══════════════════════════════════════════════════════════════════════
  section#why.why-choose
    .section-header
      h2.section-header__title Why Guests Choose Us
      p.section-header__subtitle
        | Friendly support, consistent quality, and booking that just works.
        br
        | Travel smarter with verified info and flexible options.

    .why-choose__layout
      .why-choose__image
        a.why-choose__image-placeholder(href="/hotels/2")
          img(
            src="/images/why_choose_us.jpg"
            alt="Why guests choose HotelEase"
            loading="lazy"
          )

      .why-choose__features
        +whyFeature("phone", "Customer Support", "Real people, fast replies, and help from booking to check-in.")
        +whyFeature("tag", "Best Price Guaranteed", "Fair pricing with no surprises—book confidently every time.")
        +whyFeature("map-marker-alt", "Many Location", "Handpicked cities and neighborhoods for every travel style.")

  //- ── Partner / Gallery Carousel ─────────────────────────────────────────
  .gallery
    a.gallery__item.gallery__item--active(href="/hotels/3")
      img(src="/images/gallery_01.jpg" alt="Hotel gallery image 1" loading="lazy")
    a.gallery__item(href="/hotels/4")
      img(src="/images/gallery_02.jpg" alt="Hotel gallery image 2" loading="lazy")

  //- ══════════════════════════════════════════════════════════════════════
  //- SECTION 5 — Testimonials
  //- ══════════════════════════════════════════════════════════════════════
  section#testimonial.testimonials
    .section-header
      h2.section-header__title
        | Trusted by Thousands of
        br
        | Happy Customers
      p.section-header__subtitle
        | Real guest reviews, real comfort, and rooms that match the moment.
        br
        | Book your next stay and see why travelers come back.

    .testimonials__grid
      +testimonialCard("Viezh Robert", "Warsaw, Poland", "4.5", "\"Wow... the check-in was smooth and the room felt even better than the photos. HotelEase made booking effortless—will book again.\".")
      +testimonialCard("Viezh Robert", "Warsaw, Poland", "4.5", "\"Everything was clear from the start: pricing, location, and what to expect. Great stay and zero stress with HotelEase.\".")
      +testimonialCard("Viezh Robert", "Warsaw, Poland", "4.5", "\"A really comfortable place to unwind. The details matched perfectly and the booking process was fast. Highly recommended.\".")
