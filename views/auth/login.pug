extends ../layout

block content
  section.auth
    .auth__card
      h1.auth__title Welcome back
      p.auth__subtitle Log in to continue planning your trip.

      if flash
        p.auth__message(class=flash.type === 'error' ? 'auth__message--error' : 'auth__message--success')= flash.message

      form.auth__form(action="/login" method="post")
        .auth__field
          label.auth__label(for="email") Email
          input.auth__input#email(
            type="email"
            name="email"
            placeholder="you@example.com"
            value=formData && formData.email ? formData.email : ''
            required
          )

        .auth__field
          label.auth__label(for="password") Password
          input.auth__input#password(
            type="password"
            name="password"
            placeholder="Enter your password"
            required
          )

        .auth__footer
          button.btn--primary(type="submit") Log In
          a.auth__link(href="/register") Create a new account
