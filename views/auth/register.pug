extends ../layout

block content
  section.auth
    .auth__card
      h1.auth__title Create your account
      p.auth__subtitle Join HotelEase and start planning your next stay.

      if flash
        p.auth__message(class=flash.type === 'error' ? 'auth__message--error' : 'auth__message--success')= flash.message

      form.auth__form(action="/register" method="post")
        .auth__field
          label.auth__label(for="name") Full name
          input.auth__input#name(
            type="text"
            name="name"
            placeholder="Alex Doe"
            value=formData && formData.name ? formData.name : ''
            required
          )

        .auth__field
          label.auth__label(for="email") Email
          input.auth__input#email(
            type="email"
            name="email"
            placeholder="you@example.com"
            value=formData && formData.email ? formData.email : ''
            required
          )

        .auth__field
          label.auth__label(for="password") Password
          input.auth__input#password(
            type="password"
            name="password"
            placeholder="At least 8 characters"
            required
          )

        .auth__footer
          button.btn--primary(type="submit") Sign Up
          a.auth__link(href="/login") Already have an account? Log in
