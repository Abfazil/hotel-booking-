//- views/hotel-detail.pug
//- Hotel detail page with favourite heart animation

extends layout

block content

  section.hotel-detail
    .hotel-detail__hero
      .hotel-detail__hero-inner
        .hotel-detail__breadcrumb
          a(href="/") Home
          span ›
          a(href="/hotels") Hotels
          span ›
          span= hotel.name

        .hotel-detail__header
          .hotel-detail__title-group
            h1.hotel-detail__title= hotel.name
            p.hotel-detail__location
              i.fas.fa-map-marker-alt
              |  #{hotel.location}

            .hotel-detail__rating
              span.hotel-detail__rating-badge
                i.fas.fa-star
                |  #{hotel.rating.toFixed(1)}
              span.hotel-detail__rating-caption Loved by modern travellers

          .hotel-detail__side
            .hotel-detail__price-block
              span.hotel-detail__price-label From
              span.hotel-detail__price-value $#{hotel.price.toFixed(0)}
              span.hotel-detail__price-unit / night

            button.hotel-detail__fav(type="button" aria-label="Add to favourites" data-fav-toggle data-hotel-id=hotel.id)
              i.far.fa-heart
              //- span Save to favourites

      .hotel-detail__image
        if hotel.image
          img.hotel-detail__img(src=hotel.image alt=hotel.name)
        else
          .hotel-detail__image-placeholder
            i.fas.fa-image

      .hotel-detail__layout
      .hotel-detail__main
        h2.hotel-detail__section-title About this stay
        p.hotel-detail__text
          | Step into a bright, carefully curated space with layered textiles, warm wood tones,
          |  and soft accent lighting. Every corner is designed to feel calm, welcoming, and
          |  quietly luxurious.

        p.hotel-detail__text
          | Wake up to filtered sunlight, fresh coffee, and city or sea views depending on the
          |  room type you choose. In the evening, dimmed lights and plush bedding create a
          |  gentle transition from the outside world.

        ul.hotel-detail__highlights
          li King‑size bed with premium linens
          li Soft ambient lighting with dimmers
          li Quiet, well‑insulated rooms for restful sleep
          li High‑speed Wi‑Fi and a dedicated work corner

        include reviews

      .hotel-detail__sidebar
        .hotel-detail__card
          h3.hotel-detail__card-title A cosy place to pause
          p.hotel-detail__card-text
            | This room is perfect for slow mornings, late‑night conversations, and quiet solo
            |  moments. Add it to your favourites with the heart above and come back to it later.

          if currentUser && currentUser.role === 'customer'
            form.hotel-detail__booking-form(action=`/hotels/${hotel.id}/book` method="POST")
              .hotel-detail__booking-grid
                .hotel-detail__field
                  label.hotel-detail__field-label(for="checkInDate") Check-in date
                  input.hotel-detail__field-input#checkInDate(type="date" name="checkInDate" required)
                .hotel-detail__field
                  label.hotel-detail__field-label(for="guests") Guests
                  input.hotel-detail__field-input#guests(type="number" name="guests" min="1" value="1" required)

                .hotel-detail__field
                  label.hotel-detail__field-label(for="nights") Number of nights
                  input.hotel-detail__field-input#nights(type="number" name="nights" min="1" value="1" required)
                .hotel-detail__field
                  label.hotel-detail__field-label(for="days") Number of days
                  input.hotel-detail__field-input#days(type="number" name="days" min="1" value="2" required)

                .hotel-detail__field
                  label.hotel-detail__field-label(for="roomType") Room type
                  select.hotel-detail__field-input#roomType(name="roomType" required)
                    option(value="Standard room") Standard room
                    option(value="Deluxe room") Deluxe room
                    option(value="Suite") Suite
                .hotel-detail__field
                  label.hotel-detail__field-label(for="mealPlan") Meal option
                  select.hotel-detail__field-input#mealPlan(name="mealPlan" required)
                    option(value="Breakfast only") Breakfast only
                    option(value="Half board") Half board
                    option(value="Full board") Full board

              .hotel-detail__field
                label.hotel-detail__field-label Payment option (static)
                .hotel-detail__payment-options
                  label.hotel-detail__payment-choice
                    input(type="radio" name="paymentMethod" value="Pay at hotel" checked)
                    span Pay at hotel
                  label.hotel-detail__payment-choice
                    input(type="radio" name="paymentMethod" value="Card at check-in")
                    span Card at check-in
                  label.hotel-detail__payment-choice
                    input(type="radio" name="paymentMethod" value="Bank transfer proof")
                    span Bank transfer proof

              .hotel-detail__field
                label.hotel-detail__field-label(for="specialRequests") Special requests
                textarea.hotel-detail__field-input#specialRequests(name="specialRequests" rows="3" placeholder="Any food allergy, high floor preference, extra bed, etc.")

              button.btn--primary.hotel-detail__book-btn(type="submit")
                i.fas.fa-calendar-check
                |  Book Hotel
            p.hotel-detail__card-note
              | Book this hotel now and you will be redirected to the thank you page.
          else
            p.hotel-detail__card-note
              | Please log in as a customer to book this hotel.

