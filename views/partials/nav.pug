//- views/partials/nav.pug
//- Reusable navigation component — included via `include partials/nav`

nav.navbar
  .navbar__brand
    a.navbar__logo(href="/") HotelEase

  ul.navbar__links
    li: a.navbar__link(href="/") Home
    li: a.navbar__link(href="/hotels") Hotels
    li: a.navbar__link(href="/disputes") Disputes
    if currentUser && currentUser.role === 'admin'
      li: a.navbar__link(href="/admin") Admin
    else if currentUser
      li: a.navbar__link(href="/dashboard") Dashboard
      li: a.navbar__link(href="/favourites") Favourites

  .navbar__actions
    if currentUser
      span.navbar__welcome Hello, #{currentUser.name}
      a.btn--ghost(href="/logout") Log out
    else
      a.btn--ghost(href="/register") Register
      a.btn--primary(href="/login") Log In
